{
  "name": "content-stack-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Vue 3 management UI for content-stack daemon (M0 scaffold).",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint --ext .ts,.vue,.tsx src",
    "format": "prettier --write src",
    "gen-types": "openapi-typescript http://127.0.0.1:5180/api/openapi.json -o src/api.ts --enum --root-types"
  },
  "dependencies": {
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.20.0",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.0"
  }
}
