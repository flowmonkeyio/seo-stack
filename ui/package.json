{
  "name": "content-stack-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Vue 3 management UI for content-stack daemon (M5 build).",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc --noEmit",
    "lint": "eslint --ext .ts,.vue,.tsx src",
    "format": "prettier --write src",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "playwright test",
    "gen-types": "openapi-typescript http://127.0.0.1:5180/api/openapi.json -o src/api.ts --enum --root-types"
  },
  "dependencies": {
    "dompurify": "^3.1.6",
    "marked": "^14.1.2",
    "pinia": "^2.2.4",
    "vue": "^3.4.0",
    "vue-router": "^4.3.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.48.0",
    "@types/dompurify": "^3.0.5",
    "@types/node": "^20.11.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.0",
    "eslint": "^9.0.0",
    "eslint-plugin-vue": "^9.20.0",
    "jsdom": "^25.0.1",
    "openapi-typescript": "^7.4.0",
    "postcss": "^8.4.0",
    "prettier": "^3.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.4.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^5.2.0",
    "vitest": "^2.1.4",
    "vue-eslint-parser": "^9.4.0",
    "vue-tsc": "^2.0.0"
  },
  "packageManager": "pnpm@10.28.0+sha512.05df71d1421f21399e053fde567cea34d446fa02c76571441bfc1c7956e98e363088982d940465fd34480d4d90a0668bc12362f8aa88000a64e83d0b0e47be48"
}
